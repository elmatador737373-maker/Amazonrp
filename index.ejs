<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Amazon RP Dashboard</title>
</head>
<body class="bg-[#0f1111] text-white font-sans">
    <!-- Navbar Lux -->
    <nav class="bg-[#131921] border-b border-yellow-600 p-4 flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-2">
            <span class="text-2xl font-bold text-yellow-500 underline decoration-white">amazon</span>
            <span class="text-sm font-light text-gray-300 pt-2">RP</span>
        </div>
        <div class="flex items-center gap-4">
            <% if (user) { %>
                <div class="text-right">
                    <p class="text-xs text-gray-400 italic">Account Discord</p>
                    <p class="font-bold"><%= user.username %></p>
                </div>
                <% if (isDirector) { %>
                    <button onclick="document.getElementById('adminPanel').classList.toggle('hidden')" class="bg-yellow-500 text-black px-4 py-1 rounded font-bold text-sm">GESTISCI</button>
                <% } %>
                <a href="/logout" class="text-red-500 text-xs">Esci</a>
            <% } else { %>
                <a href="/auth/discord" class="bg-yellow-500 text-black px-6 py-2 rounded font-bold">ACCEDI</a>
            <% } %>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-6xl mx-auto p-6">
        <!-- Pannello Admin (Nascosto) -->
        <div id="adminPanel" class="hidden bg-white text-black p-6 rounded-lg mb-8 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="border-r pr-6">
                <h3 class="font-bold mb-4 border-b">⚙️ Configurazione Ruoli/Bot</h3>
                <form action="/api/admin/settings" method="POST" class="space-y-2">
                    <input type="text" name="guild_id" placeholder="ID Server" class="w-full border p-1" value="<%= settings?.guild_id %>">
                    <input type="text" name="director_role_id" placeholder="ID Ruolo Direttore" class="w-full border p-1" value="<%= settings?.director_role_id %>">
                    <input type="text" name="courier_role_id" placeholder="ID Ruolo Corriere" class="w-full border p-1" value="<%= settings?.courier_role_id %>">
                    <input type="text" name="webhook_url" placeholder="URL Webhook" class="w-full border p-1" value="<%= settings?.webhook_url %>">
                    <button class="bg-green-600 text-white w-full py-2 rounded">Salva Config</button>
                </form>
            </div>
            <div>
                <h3 class="font-bold mb-4 border-b">📦 Aggiungi Prodotto</h3>
                <form action="/api/admin/add-product" method="POST" class="space-y-2">
                    <input type="text" name="name" placeholder="Nome Oggetto" class="w-full border p-1">
                    <input type="number" name="price" placeholder="Prezzo Retail" class="w-full border p-1">
                    <input type="number" name="wholesale_price" placeholder="Prezzo Ingrosso" class="w-full border p-1">
                    <input type="number" name="min_wholesale" placeholder="Minimo Ingrosso" class="w-full border p-1">
                    <input type="text" name="image" placeholder="URL Immagine" class="w-full border p-1">
                    <button class="bg-black text-white w-full py-2 rounded">Pubblica</button>
                </form>
            </div>
        </div>

        <h2 class="text-2xl font-bold mb-6">Offerte del Giorno</h2>
        
        <!-- Grid Prodotti -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <% products.forEach(p => { %>
                <div class="bg-[#232f3e] rounded p-4 flex flex-col hover:border border-yellow-500 shadow-xl transition-all">
                    <img src="<%= p.image %>" class="h-40 w-full object-contain mb-4 bg-white rounded">
                    <h4 class="font-bold text-lg leading-tight mb-2"><%= p.name %></h4>
                    <div class="mt-auto">
                        <p class="text-yellow-500 text-xl font-bold">$<%= p.price %></p>
                        <p class="text-xs text-gray-400 mb-4 italic">Ingrosso: $<%= p.wholesale_price %> (min. <%= p.min_wholesale %>)</p>
                        <div class="flex gap-2">
                            <button onclick="buy('<%= p.id %>', 'retail')" class="bg-yellow-500 text-black text-xs font-bold py-2 px-2 rounded w-full">RETAIL</button>
                            <button onclick="buy('<%= p.id %>', 'wholesale')" class="bg-[#f0c14b] text-black text-xs font-bold py-2 px-2 rounded w-full">WHOLESALE</button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        async function buy(id, type) {
            const res = await fetch('/api/buy', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ productId: id, type: type })
            });
            const data = await res.json();
            if(data.success) alert("✅ Ordine effettuato! Controlla Discord.");
            else alert("❌ Errore: " + data.message);
        }
    </script>
</body>
</html>

